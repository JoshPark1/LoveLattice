# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node modules
node_modules/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Server environment & dynamic tracking files
apps/server-legacy/.env
apps/server-legacy/db.json
apps/server-legacy/storageState.json

# Server dynamic media (thumbnails downloaded by bot)
apps/server-legacy/public/thumbnails/*
!apps/server-legacy/public/thumbnails/.gitkeep

# Reference face photos uploaded by user (personal data)
apps/server-legacy/uploads/*
!apps/server-legacy/uploads/.gitkeep

# Temp story downloads (should be cleaned up at runtime, but just in case)
apps/server-legacy/_temp_story_*.jpg

# Local data directory runtime files (db, config, scan state — keep folders via .gitkeep)
data/*.json
!data/.gitkeep
data/thumbnails/*
!data/thumbnails/.gitkeep
data/uploads/*
!data/uploads/.gitkeep

# Next.js build output
.next/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
